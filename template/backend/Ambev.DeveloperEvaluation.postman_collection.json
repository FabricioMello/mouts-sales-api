{
  "info": {
    "_postman_id": "3ecb14ec-25f2-4d18-b710-7c8abff35c11",
    "name": "Ambev Developer Evaluation API",
    "description": "Collection for testing Auth, Users and Sales endpoints. Run Users > Create user first if the login user does not exist, then run Auth > Login to fill the authToken variable. Users and Sales inherit the bearer token from the collection.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{authToken}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.test('Response is not 5xx', function () {",
          "  pm.expect(pm.response.code).to.be.below(500);",
          "});"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "authToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "userEmail",
      "value": "admin.sales@test.com",
      "type": "string"
    },
    {
      "key": "userPassword",
      "value": "Str0ng!Pass123",
      "type": "string"
    },
    {
      "key": "userId",
      "value": "",
      "type": "string"
    },
    {
      "key": "saleId",
      "value": "",
      "type": "string"
    },
    {
      "key": "saleItemId",
      "value": "",
      "type": "string"
    },
    {
      "key": "customerId",
      "value": "7b76de6a-9b1b-4f45-ae3d-4c58472d47af",
      "type": "string"
    },
    {
      "key": "branchId",
      "value": "1dd18eb8-9e4d-4ee3-ae8d-2d1f7cd56211",
      "type": "string"
    },
    {
      "key": "productId1",
      "value": "dfac8337-4a1d-43b1-8ec7-9a72741f0780",
      "type": "string"
    },
    {
      "key": "productId2",
      "value": "6fc4160f-3994-4cf9-a2c6-46326f53afc0",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login returned token', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.success).to.eql(true);",
                  "  pm.expect(json.data.token).to.be.a('string').and.not.empty;",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "if (json && json.data && json.data.token) {",
                  "  pm.collectionVariables.set('authToken', json.data.token);",
                  "  pm.collectionVariables.set('userEmail', json.data.email || pm.collectionVariables.get('userEmail'));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/Auth",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "Auth"
              ]
            },
            "description": "Authenticates the user and stores data.token in the authToken collection variable."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Create user",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  if (json && json.data && json.data.id) {",
                  "    pm.collectionVariables.set('userId', json.data.id);",
                  "  }",
                  "}",
                  "",
                  "pm.test('User created or already exists', function () {",
                  "  pm.expect([201, 400, 409, 500]).to.include(pm.response.code);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"Sales Admin\",\n  \"password\": \"{{userPassword}}\",\n  \"phone\": \"+5511999999999\",\n  \"email\": \"{{userEmail}}\",\n  \"status\": 1,\n  \"role\": 3\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/Users",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "Users"
              ]
            },
            "description": "Creates a user that can be used by Auth > Login. status: 1 Active. role: 3 Admin."
          },
          "response": []
        },
        {
          "name": "Get user by id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/Users/{{userId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "Users",
                "{{userId}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Delete user",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/Users/{{userId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "Users",
                "{{userId}}"
              ]
            },
            "description": "Deletes the user by id. Use carefully if this user is the one used for login."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Sales",
      "item": [
        {
          "name": "List sales",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/Sales?_page=1&_size=10",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "Sales"
              ],
              "query": [
                {
                  "key": "_page",
                  "value": "1"
                },
                {
                  "key": "_size",
                  "value": "10"
                },
                {
                  "key": "_saleNumber",
                  "value": "",
                  "disabled": true
                },
                {
                  "key": "_customerId",
                  "value": "{{customerId}}",
                  "disabled": true
                },
                {
                  "key": "_customerName",
                  "value": "Test Customer",
                  "disabled": true
                },
                {
                  "key": "_branchId",
                  "value": "{{branchId}}",
                  "disabled": true
                },
                {
                  "key": "_branchName",
                  "value": "Main Branch",
                  "disabled": true
                },
                {
                  "key": "_isCancelled",
                  "value": "false",
                  "disabled": true
                },
                {
                  "key": "_saleDateFrom",
                  "value": "2026-01-01T00:00:00Z",
                  "disabled": true
                },
                {
                  "key": "_saleDateTo",
                  "value": "2026-12-31T23:59:59Z",
                  "disabled": true
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Create sale",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Sale created', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  if (json && json.data && json.data.id) {",
                  "    pm.collectionVariables.set('saleId', json.data.id);",
                  "  }",
                  "  if (json && json.data && json.data.items && json.data.items.length > 0) {",
                  "    pm.collectionVariables.set('saleItemId', json.data.items[0].id);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"saleNumber\": \"SALE-{{$timestamp}}\",\n  \"saleDate\": \"2026-04-25T12:00:00Z\",\n  \"customerId\": \"{{customerId}}\",\n  \"customerName\": \"Test Customer\",\n  \"branchId\": \"{{branchId}}\",\n  \"branchName\": \"Main Branch\",\n  \"items\": [\n    {\n      \"productId\": \"{{productId1}}\",\n      \"productName\": \"Premium Beer Pack\",\n      \"quantity\": 4,\n      \"unitPrice\": 10.50\n    },\n    {\n      \"productId\": \"{{productId2}}\",\n      \"productName\": \"Craft Beer Pack\",\n      \"quantity\": 10,\n      \"unitPrice\": 8.00\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/Sales",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "Sales"
              ]
            },
            "description": "Creates a sale and stores data.id as saleId and the first item id as saleItemId."
          },
          "response": []
        },
        {
          "name": "Get sale by id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/Sales/{{saleId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "Sales",
                "{{saleId}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Cancel sale item",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/Sales/{{saleId}}/items/{{saleItemId}}/cancel",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "Sales",
                "{{saleId}}",
                "items",
                "{{saleItemId}}",
                "cancel"
              ]
            },
            "description": "Cancels one item and returns the sale with recalculated total for active items."
          },
          "response": []
        },
        {
          "name": "Cancel sale",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/Sales/{{saleId}}/cancel",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "Sales",
                "{{saleId}}",
                "cancel"
              ]
            },
            "description": "Cancels the whole sale and preserves the historical sale total."
          },
          "response": []
        }
      ]
    }
  ]
}
